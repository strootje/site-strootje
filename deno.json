{
  "tasks": {
    "dev": "vite dev",
    "build": "vite build"
  },

  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",

    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom"
    ],

    "types": [
      "vite/client"
    ]
  },

  "workspace": [
    "pkgs/**"
  ],

  "imports": {
    "#/": "./src/",
    "@std/path": "jsr:@std/path@^1.1.5",
    "content-collections": "./.content-collections/generated/index.js"
  },

  "fmt": {
    "lineWidth": 120
  },

  "lint": {
    "plugins": [
      "jsr:@ryu/deno-lint-plugin-tailwindcss@0.2.0"
    ]
  },

  "test": {
    "include": [
      "**/*.test.ts"
    ]
  },
  "allowScripts": ["npm:@parcel/watcher@2.5.6", "npm:esbuild@0.27.3"]
}
